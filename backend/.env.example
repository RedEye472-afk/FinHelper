# ===== FinHelper backend environment =====
# Copy to .env and fill real values. Never commit .env.

# ----- Database -----
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://finhelper:finhelper_pass@localhost:5432/finhelper?sslmode=disable

# ----- HTTP server -----
HTTP_ADDR=:8080
# Comma-separated list of allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ----- Auth / JWT -----
# 32+ random bytes; generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-access-secret-please-32+chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-please-32+chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
# Salt mixed into user_hash = SHA-256(user_id || USER_HASH_SALT). Random.
USER_HASH_SALT=change-me-random-salt

# ----- Logging -----
LOG_LEVEL=info
# Pretty console output for dev; json for prod
LOG_FORMAT=console
